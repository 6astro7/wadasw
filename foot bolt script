-- Foot Bolt - FINAL (SEM FOV + Ball Speed + UI CLEAN)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer

-- Config
local customWalkSpeed = 65
local ballSpeed = 65 -- speed com bola
local reachSize = 4.5
local hipHeightValue = 1.8

local isInfiniteStamina = true
local isReachEnabled = true
local isAntiTackle = true
local showReach = false

-- GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = player:WaitForChild("PlayerGui")

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 320, 0, 600)
Frame.Position = UDim2.new(0.5, -160, 0.5, -300)
Frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
Frame.BorderSizePixel = 0
Frame.Parent = ScreenGui

Instance.new("UICorner", Frame).CornerRadius = UDim.new(0,12)

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1,0,0,45)
Title.BackgroundColor3 = Color3.fromRGB(0,140,255)
Title.Text = "Foot Bolt - PRO"
Title.TextColor3 = Color3.new(1,1,1)
Title.TextScaled = true
Title.BorderSizePixel = 0
Title.Parent = Frame

Instance.new("UICorner", Title).CornerRadius = UDim.new(0,12)

local function createToggle(txt,y,state)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0.9,0,0,40)
    b.Position = UDim2.new(0.05,0,y,0)
    b.BackgroundColor3 = Color3.fromRGB(35,35,35)
    b.Text = txt..": "..(state and "ON" or "OFF")
    b.TextColor3 = Color3.new(1,1,1)
    b.BorderSizePixel = 0
    b.Parent = Frame
    Instance.new("UICorner", b).CornerRadius = UDim.new(0,8)
    return b
end

local function createBox(txt,y,val)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(0.9,0,0,20)
    l.Position = UDim2.new(0.05,0,y,0)
    l.BackgroundTransparency = 1
    l.Text = txt..val
    l.TextColor3 = Color3.new(1,1,1)
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Parent = Frame

    local b = Instance.new("TextBox")
    b.Size = UDim2.new(0.9,0,0,35)
    b.Position = UDim2.new(0.05,0,y+0.03,0)
    b.BackgroundColor3 = Color3.fromRGB(40,40,40)
    b.Text = tostring(val)
    b.TextColor3 = Color3.new(1,1,1)
    b.BorderSizePixel = 0
    b.Parent = Frame
    Instance.new("UICorner", b).CornerRadius = UDim.new(0,8)

    return l,b
end

-- TOGGLES
local ToggleStamina = createToggle("Stamina",0.10,true)
local ToggleReach = createToggle("Reach",0.18,true)
local ToggleAntiTackle = createToggle("Anti-Tackle",0.26,true)
local ToggleShowReach = createToggle("Clip Mode",0.34,false)

-- BOXES
local WSLabel,WSTextBox = createBox("Speed: ",0.42,customWalkSpeed)
local BallLabel,BallBox = createBox("Speed com bola: ",0.50,ballSpeed)
local ReachLabel,ReachBox = createBox("Reach: ",0.58,reachSize)
local HeightLabel,HeightBox = createBox("Altura: ",0.66,hipHeightValue)

-- TOGGLES FUNC
ToggleStamina.MouseButton1Click:Connect(function()
    isInfiniteStamina = not isInfiniteStamina
    ToggleStamina.Text = "Stamina: "..(isInfiniteStamina and "ON" or "OFF")
end)

ToggleReach.MouseButton1Click:Connect(function()
    isReachEnabled = not isReachEnabled
end)

ToggleAntiTackle.MouseButton1Click:Connect(function()
    isAntiTackle = not isAntiTackle
end)

ToggleShowReach.MouseButton1Click:Connect(function()
    showReach = not showReach
end)

-- INPUTS
WSTextBox.FocusLost:Connect(function()
    local n = tonumber(WSTextBox.Text)
    if n then customWalkSpeed = n end
end)

BallBox.FocusLost:Connect(function()
    local n = tonumber(BallBox.Text)
    if n then ballSpeed = n end
end)

ReachBox.FocusLost:Connect(function()
    local n = tonumber(ReachBox.Text)
    if n then reachSize = math.clamp(n,3,12) end
end)

HeightBox.FocusLost:Connect(function()
    local n = tonumber(HeightBox.Text)
    if n then hipHeightValue = math.clamp(n,0.5,4) end
end)

-- LOOP
RunService.Heartbeat:Connect(function()
    local char = player.Character
    if not char then return end

    local hum = char:FindFirstChild("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    -- ⚽ SPEED COM BOLA
    local hasBall = char:FindFirstChild("Ball") or char:FindFirstChild("Football")
    if hasBall then
        hum.WalkSpeed = ballSpeed
    else
        hum.WalkSpeed = customWalkSpeed
    end

    -- STAMINA
    if isInfiniteStamina then
        for _,v in pairs(char:GetDescendants()) do
            if v:IsA("NumberValue") or v:IsA("IntValue") then
                if v.Name:lower():find("stamina") then
                    v.Value = 100
                end
            end
        end
    end

    -- REACH
    if isReachEnabled then
        root.Size = Vector3.new(reachSize,reachSize,reachSize)
        root.CanCollide = false
        hum.HipHeight = hipHeightValue

        if showReach then
            root.Transparency = 0.3
        else
            root.Transparency = 1
        end
    end

    -- ANTI-TACKLE
    if isAntiTackle then
        if hum:GetState() == Enum.HumanoidStateType.FallingDown then
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
    end
end)

-- TOGGLE MENU
UserInputService.InputBegan:Connect(function(i,g)
    if not g and i.KeyCode == Enum.KeyCode.RightShift then
        ScreenGui.Enabled = not ScreenGui.Enabled
    end
end)

print("🔥 VERSION SEM FOV PRONTA")
